{
  "manifest_version": 3,
  "name": "PageScribe",
  "version": "1.0",
  "description": "Screenshot PDF pages in browser",
  "permissions": ["downloads", "tabs", "activeTab", "storage"],
  "host_permissions": ["<all_urls>", "http://localhost/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  }
}
